.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Database files
*.db
*.db-shm
*.db-wal

# Logs
*.log

# Temp build artifacts
build_error*.txt
build_output*.txt

# Python
__pycache__/
*.pyc
*.pyo

# Comate specs
.comate/

# PyInstaller
dist/build_*/

# Large binary archives
install/NEVO.zip
*.zip
!src/client/gui_python/translations/*.json
!src/server/gui_python/translations/*.json

# Binary distributions
dist/NEVO-*/
test/

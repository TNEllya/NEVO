# ============================================================
# NEVO Server Configuration
# ============================================================
# Copy this file to .env and customize for your deployment.

# --- Docker Registry (for pull.sh / docker-compose.pull.yml) ---
# GitHub Container Registry repository owner (your GitHub username or org)
NEVO_REPO_OWNER=your-username
# Image tag to pull (latest, v0.1.0, sha-abc1234, etc.)
NEVO_IMAGE_TAG=latest

# --- Server Settings ---
# Timezone
TZ=Asia/Shanghai

# Server Identity
NEVO_SERVER_NAME=NEVO Server

# Port Configuration
NEVO_TCP_PORT=24430
NEVO_UDP_PORT=24431
NEVO_VIDEO_UDP_PORT=24432

# Server Capacity
NEVO_MAX_USERS=100
NEVO_THREADS=4

# Logging
NEVO_LOG_LEVEL=info

# Resource Limits
NEVO_CPU_LIMIT=2
NEVO_MEMORY_LIMIT=512M

# --- GitHub Container Registry Authentication (optional) ---
# For private repositories, set these to pull images from GHCR.
# For public repos, leave empty (anonymous pull).
# GITHUB_USER=your-github-username
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
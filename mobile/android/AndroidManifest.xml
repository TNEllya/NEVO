<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ AndroidManifest.xml
  ~ NEVO VoIP Android Manifest
  ~
  ~ Declares required permissions and the foreground audio service
  ~ for background VoIP operation on Android.
  ~
  ~ Permissions:
  ~   - RECORD_AUDIO: Microphone access for voice capture
  ~   - FOREGROUND_SERVICE: Required for running a foreground service
  ~   - FOREGROUND_SERVICE_MEDIA_PLAYBACK: Specific foreground service type for audio playback
  ~   - INTERNET: Network access for VoIP signaling and voice transport
  ~   - WAKE_LOCK: Keep CPU alive during background VoIP calls
  -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.nevo.voip">

    <!-- Microphone permission for voice capture -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Foreground service permissions for background audio -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Network permission for VoIP signaling and voice transport -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Keep CPU alive during background VoIP calls -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/AppTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          ~ NEVO Audio Foreground Service
          ~
          ~ This service keeps the VoIP audio pipeline running when the
          ~ app is in the background. It displays a persistent notification
          ~ so the user is aware that audio is active.
          ~
          ~ foregroundServiceType="mediaPlayback" is required on Android 14+
          ~ to declare that this service plays media audio in the foreground.
          -->
        <service
            android:name=".NevoAudioService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

    </application>

</manifest>
